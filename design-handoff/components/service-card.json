{
  "component": "ServiceCard",
  "description": "Salon card displaying key information with image, ratings, and booking CTA",
  "variants": {
    "size": {
      "options": ["default"],
      "default": "default"
    },
    "state": {
      "options": ["default", "pressed", "loading", "error"],
      "default": "default"
    }
  },
  "states": {
    "default": {
      "background": "#FFFFFF",
      "border": {
        "width": 1,
        "color": "#E5E0D1"
      },
      "shadow": "0px 2px 4px rgba(0, 0, 0, 0.08)"
    },
    "pressed": {
      "background": "#FFFFFF",
      "border": {
        "width": 1,
        "color": "#E3A9A0"
      },
      "shadow": "0px 2px 4px rgba(0, 0, 0, 0.08)",
      "transform": "scale(0.99)"
    },
    "loading": {
      "background": "#FFFFFF",
      "border": {
        "width": 1,
        "color": "#E5E0D1"
      },
      "shadow": "none",
      "opacity": 0.6,
      "content": {
        "showSkeleton": true,
        "skeletonColor": "#F5F5F5",
        "pulseAnimation": {
          "duration": 1500,
          "easing": "ease-in-out"
        }
      }
    },
    "error": {
      "background": "#FFFFFF",
      "border": {
        "width": 1,
        "color": "#F44336"
      },
      "shadow": "none",
      "content": {
        "hideImage": false,
        "imageFallback": {
          "background": "#FEE",
          "iconColor": "#F44336",
          "iconName": "alert-circle",
          "iconSize": 24
        },
        "errorMessageSlot": {
          "visible": true,
          "position": "below image",
          "padding": 12,
          "background": "rgba(244, 67, 54, 0.05)",
          "borderRadius": 8,
          "text": {
            "style": "body-small",
            "color": "#F44336",
            "content": "Unable to load salon details"
          }
        },
        "retryAffordance": {
          "type": "button",
          "label": "Retry",
          "position": "inside error message slot",
          "style": {
            "paddingHorizontal": 12,
            "paddingVertical": 6,
            "background": "#F44336",
            "color": "#FFFFFF",
            "borderRadius": 8,
            "fontSize": 12,
            "fontWeight": 500
          },
          "accessibility": {
            "role": "button",
            "label": "Retry loading salon details",
            "hint": "Tap to attempt loading this salon again"
          }
        }
      },
      "accessibility": {
        "role": "button",
        "label": "Salon card. Error loading details.",
        "hint": "Tap retry button to reload",
        "liveRegion": "polite"
      }
    }
  },
  "layout": {
    "width": "100%",
    "borderRadius": 16,
    "padding": 16,
    "gap": 12
  },
  "structure": {
    "image": {
      "width": "100%",
      "aspectRatio": "16:9",
      "borderRadius": 12,
      "position": "relative",
      "children": ["favoriteButton", "memberBadge"]
    },
    "favoriteButton": {
      "position": "absolute",
      "top": 8,
      "right": 8,
      "size": 36,
      "background": "rgba(255, 255, 255, 0.9)",
      "backdropFilter": "blur(4px)",
      "borderRadius": 9999,
      "icon": {
        "name": "heart",
        "size": 20,
        "color": {
          "default": "#6B6B6B",
          "active": "#E3A9A0"
        }
      }
    },
    "content": {
      "gap": 8
    },
    "header": {
      "flexDirection": "row",
      "justifyContent": "space-between",
      "alignItems": "flex-start",
      "gap": 8
    },
    "salonName": {
      "style": "heading-4",
      "color": "#1A1A1A",
      "numberOfLines": 1,
      "flex": 1
    },
    "memberBadge": {
      "background": "#E3A9A0",
      "color": "#FFFFFF",
      "paddingHorizontal": 8,
      "paddingVertical": 4,
      "borderRadius": 9999,
      "style": "label-small"
    },
    "rating": {
      "flexDirection": "row",
      "alignItems": "center",
      "gap": 4
    },
    "ratingIcon": {
      "name": "star",
      "size": 16,
      "color": "#E3A9A0",
      "fill": "#E3A9A0"
    },
    "ratingText": {
      "style": "body-small",
      "fontWeight": 500
    },
    "reviewCount": {
      "style": "body-small",
      "color": "#6B6B6B"
    },
    "categories": {
      "flexDirection": "row",
      "flexWrap": "wrap",
      "gap": 4
    },
    "categoryChip": {
      "background": "rgba(209, 191, 179, 0.2)",
      "paddingHorizontal": 8,
      "paddingVertical": 4,
      "borderRadius": 9999,
      "style": "body-small"
    },
    "availability": {
      "flexDirection": "row",
      "justifyContent": "space-between",
      "style": "body-small",
      "color": "#6B6B6B"
    },
    "footer": {
      "borderTopWidth": 1,
      "borderTopColor": "#E5E0D1",
      "paddingTop": 8,
      "flexDirection": "row",
      "justifyContent": "space-between",
      "alignItems": "center"
    },
    "exampleService": {
      "style": "body-small",
      "color": "#6B6B6B"
    },
    "price": {
      "style": "body-small",
      "fontWeight": 600,
      "color": "#E3A9A0"
    }
  },
  "transitions": {
    "onPress": {
      "duration": 100,
      "easing": "ease-out",
      "properties": ["transform", "border"]
    },
    "toLoading": {
      "duration": 200,
      "easing": "ease-in",
      "properties": ["opacity"]
    },
    "toError": {
      "duration": 300,
      "easing": "ease-out",
      "properties": ["border"]
    }
  },
  "accessibility": {
    "role": "button",
    "label": "{salonName}, {rating} stars, {categories}, from £{price}",
    "hint": "Tap to view salon details and services",
    "states": {
      "loading": {
        "label": "Loading salon details",
        "hint": "Please wait"
      },
      "error": {
        "label": "Salon card. Error loading details.",
        "hint": "Tap retry button to reload"
      }
    }
  },
  "errorHandling": {
    "networkError": {
      "message": "Unable to load salon details",
      "retryEnabled": true,
      "retryLabel": "Retry"
    },
    "imageLoadError": {
      "fallbackBackground": "#FEE",
      "fallbackIcon": "alert-circle",
      "fallbackIconColor": "#F44336"
    }
  }
}
