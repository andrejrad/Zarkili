{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Zarkili Typography Tokens",
  "version": "1.0.0",
  "fontFamily": {
    "primary": {
      "value": "Manrope, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "description": "Primary font stack"
    }
  },
  "fontWeights": {
    "light": {
      "value": 300,
      "description": "Light weight"
    },
    "regular": {
      "value": 400,
      "description": "Regular weight"
    },
    "medium": {
      "value": 500,
      "description": "Medium weight"
    },
    "semibold": {
      "value": 600,
      "description": "Semibold weight"
    }
  },
  "textStyles": {
    "heading-1": {
      "fontSize": 32,
      "lineHeight": 40,
      "fontWeight": 600,
      "letterSpacing": -0.5,
      "description": "Page titles, hero text"
    },
    "heading-2": {
      "fontSize": 24,
      "lineHeight": 32,
      "fontWeight": 600,
      "letterSpacing": -0.25,
      "description": "Section headers"
    },
    "heading-3": {
      "fontSize": 20,
      "lineHeight": 28,
      "fontWeight": 600,
      "letterSpacing": 0,
      "description": "Subsection headers"
    },
    "heading-4": {
      "fontSize": 18,
      "lineHeight": 24,
      "fontWeight": 600,
      "letterSpacing": 0,
      "description": "Card titles"
    },
    "body-large": {
      "fontSize": 16,
      "lineHeight": 24,
      "fontWeight": 400,
      "letterSpacing": 0,
      "description": "Large body text"
    },
    "body": {
      "fontSize": 14,
      "lineHeight": 20,
      "fontWeight": 400,
      "letterSpacing": 0,
      "description": "Default body text"
    },
    "body-small": {
      "fontSize": 12,
      "lineHeight": 16,
      "fontWeight": 400,
      "letterSpacing": 0,
      "description": "Small body text, captions"
    },
    "label-large": {
      "fontSize": 16,
      "lineHeight": 24,
      "fontWeight": 500,
      "letterSpacing": 0.15,
      "description": "Large button labels"
    },
    "label": {
      "fontSize": 14,
      "lineHeight": 20,
      "fontWeight": 500,
      "letterSpacing": 0.1,
      "description": "Button labels, tabs"
    },
    "label-small": {
      "fontSize": 12,
      "lineHeight": 16,
      "fontWeight": 500,
      "letterSpacing": 0.5,
      "description": "Small labels, badges"
    },
    "overline": {
      "fontSize": 10,
      "lineHeight": 16,
      "fontWeight": 600,
      "letterSpacing": 1.5,
      "textTransform": "uppercase",
      "description": "Overline text, category labels"
    }
  }
}
