{
  "name": "zarkili-functions",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "serve": "firebase emulators:start --only functions --project zarkili-dev",
    "deploy:dev": "firebase deploy --only functions --project zarkili-dev",
    "deploy:prod": "firebase deploy --only functions --project zarkili-production",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "typescript": "~5.8.3",
    "vitest": "^4.1.4"
  }
}
